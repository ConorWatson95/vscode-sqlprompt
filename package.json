{
    "name": "vscode-sqlprompt",
    "displayName": "SQL Prompt",
    "description": "SQL Server IntelliSense - schema-aware autocomplete like Redgate SQL Prompt",
    "version": "0.1.14",
    "publisher": "borile91",
    "repository": {
        "type": "git",
        "url": "https://github.com/borile91/vscode-sqlprompt.git"
    },
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages",
        "Formatters"
    ],
    "extensionDependencies": [
        "ms-mssql.mssql"
    ],
    "activationEvents": [
        "onLanguage:sql"
    ],
    "main": "./client/dist/extension",
    "contributes": {
        "languages": [
            {
                "id": "sql",
                "aliases": [
                    "SQL",
                    "sql"
                ],
                "extensions": [
                    ".sql"
                ]
            }
        ],
        "configuration": {
            "type": "object",
            "title": "SQL Prompt Configuration",
            "properties": {
                "sqlPrompt.trace.server": {
                    "scope": "window",
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the language server."
                },
                "sqlPrompt.suppressMssqlIntellisense": {
                    "scope": "window",
                    "type": "boolean",
                    "default": true,
                    "description": "When connected, automatically disable the mssql extension's IntelliSense so that SQL Prompt completions appear exclusively. Connection features (Script As, Alter Procedure, etc.) are unaffected. Set to false to let both providers coexist."
                },
                "sqlPrompt.formatting.stylesFolder": {
                    "scope": "resource",
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to the folder containing SQL Prompt style files (.json). All .json files in the folder are loaded as formatting profiles."
                },
                "sqlPrompt.formatting.activeStyle": {
                    "scope": "resource",
                    "type": "string",
                    "default": "",
                    "description": "Name of the active formatting style (the style's metadata.name, or the filename without .json). Set via the 'SQL Prompt: Select Formatting Style' command."
                }
            }
        },
        "commands": [
            {
                "command": "sqlPrompt.connect",
                "title": "SQL Prompt: Connect to Database"
            },
            {
                "command": "sqlPrompt.disconnect",
                "title": "SQL Prompt: Disconnect"
            },
            {
                "command": "sqlPrompt.reloadSchema",
                "title": "SQL Prompt: Reload Schema"
            },
            {
                "command": "sqlPrompt.selectFormattingStyle",
                "title": "SQL Prompt: Select Formatting Style"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run webpack",
        "webpack": "webpack --mode production",
        "webpack:dev": "webpack --mode development",
        "compile": "tsc -b",
        "watch": "tsc -b -w",
        "postinstall": "cd client && npm install && cd ../server && npm install"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "ts-loader": "^9.5.7",
        "typescript": "^5.3.3",
        "webpack": "^5.106.2",
        "webpack-cli": "^7.0.2"
    }
}